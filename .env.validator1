# Tenet Validator Node 1 — Testnet (Amoy, Chain ID 2049)
# Copy to .env on VPS 1 and launch: node index.js

P2P_PORT=6001
RPC_PORT=3000
VALIDATOR_ID=1
CHAIN_ID=2049

# Comma-separated ws:// addresses of peers (add validators 2 + 3 once deployed)
PEERS=

# Data directory (SQLite persistence)
# DATA_DIR=/var/tenet/node-1

# Set to your server's public IP for external peer discovery
# NODE_HOST=1.2.3.4
