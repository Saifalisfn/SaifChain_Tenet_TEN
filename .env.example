# Default single-node configuration
# Copy this file to .env and adjust values as needed.
# NEVER commit your real .env file!

# ── Node Identity ───────────────────────────────────────
VALIDATOR_ID=1           # Unique numeric ID for this node (1, 2, 3, …)

# ── Network ─────────────────────────────────────────────
P2P_PORT=6001            # WebSocket P2P port
RPC_PORT=3000            # JSON-RPC HTTP port

# Comma-separated list of bootstrap peer WebSocket URLs.
# Leave empty for a standalone genesis node.
PEERS=

# ── Chain ───────────────────────────────────────────────
CHAIN_ID=2049            # 2049 = Amoy Testnet | 2048 = Mainnet

# ── Data Storage ────────────────────────────────────────
# Directory where this node persists its chain state.
# Defaults to: ./data/node-{VALIDATOR_ID}
# DATA_DIR=./data/node-1

# ── Logging ─────────────────────────────────────────────
# LOG_LEVEL=info           # debug | info | warn | error
